APP_ENV=local
LOG_LEVEL=INFO

HF_TOKEN=

AWS_REGION=ap-northeast-2
S3_BUCKET_AUDIO=utterai-dev-raw-audio
S3_BUCKET_REPORT=utterai-dev-reports
S3_BUCKET_RAG=utterai-dev-rag-ingest
S3_BUCKET_TRANSCRIPT=utterai-dev-transcripts

# AI DB (pgvector - RAG 벡터 검색용)
DB_USER=utterai
DB_PASSWORD=utterai
DB_HOST=localhost
DB_PORT=5432
DB_NAME=utterai_ai

# BE RDS (ML GPU Worker가 transcripts / analysis_jobs 테이블에 쓸 때 사용)
BE_DB_USER=
BE_DB_PASSWORD=
BE_DB_HOST=
BE_DB_PORT=5432
BE_DB_NAME=

SQS_AUDIO_PREPROCESS_QUEUE_URL=
SQS_GPU_INFERENCE_QUEUE_URL=
SQS_REPORT_ANALYSIS_QUEUE_URL=
SQS_RAG_INGEST_QUEUE_URL=

BEDROCK_REGION=ap-northeast-2
BEDROCK_REPORT_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
AGENTCORE_AGENT_ID=
AGENTCORE_AGENT_ALIAS_ID=PROD
VAD_MODEL_NAME=onnx-community/silero-vad
DIARIZATION_MODEL_NAME=pyannote/speaker-diarization-3.1
ASR_MODEL_NAME=large-v3-turbo
EMBEDDING_MODEL_NAME=nlpai-lab/KURE-v1

# 로컬 테스트: cpu / GPU 서버: cuda
MODEL_DEVICE=auto
ASR_DEVICE=cpu
DIARIZATION_DEVICE=cpu
LLM_DEVICE=cpu

RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.5

OTEL_SERVICE_NAME=ai
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_METRICS_EXPORTER=otlp
OTEL_TRACES_EXPORTER=otlp
OTEL_LOGS_EXPORTER=none
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local,team=utterai

PUBMED_EMAIL=
PUBMED_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=