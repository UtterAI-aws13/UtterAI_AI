FROM pytorch/pytorch:2.4.1-cuda12.1-cudnn9-runtime

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

RUN apt-get update && apt-get install -y \
    ffmpeg \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --extra gpu

# pyannote.audio 3.x + huggingface_hub 0.22+ 호환성 패치
COPY scripts/patch_pyannote.py scripts/patch_pyannote.py
RUN uv run python scripts/patch_pyannote.py

COPY app ./app

ENV PYTHONPATH=/app
ENV PATH="/app/.venv/bin:$PATH"
ENV HF_HOME=/tmp/huggingface
ENV TRANSFORMERS_CACHE=/tmp/huggingface

RUN adduser --disabled-password --uid 1000 appuser
USER 1000

# ml-gpu-worker 기본값. llm-gpu-worker는 K8s Deployment command로 오버라이드.
CMD ["python", "-m", "app.workers.ml_gpu_worker"]
